<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="Gate City IT provides managed IT services for small businesses in Greensboro, NC. Cybersecurity, help desk, cloud services and more." />
  <title>Gate City IT | Managed IT Support in Greensboro, NC</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: system-ui, -apple-system, sans-serif; color: #1a1a1a; line-height: 1.6; }
    a { color: inherit; text-decoration: none; }

    /* Colors */
    :root {
      --purple-dark:  #3b1f6e;
      --purple-mid:   #5a2d9c;
      --purple-light: #f3eefe;
      --purple-accent:#7c3fc8;
      --gray-light:   #f4f4f6;
      --gray-mid:     #6b7280;
      --gray-dark:    #374151;
      --white:        #ffffff;
    }

    /* Nav */
    nav {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 12px 32px;
      background: var(--purple-dark);
      position: sticky;
      top: 0;
      z-index: 10;
    }
    .logo img {
      height: 56px;
      width: auto;
      display: block;
    }
    .nav-cta {
      background: var(--white);
      color: var(--purple-dark);
      padding: 10px 20px;
      border-radius: 6px;
      font-size: 14px;
      font-weight: 600;
      border: none;
      cursor: pointer;
      text-decoration: none;
    }
    .nav-cta:hover { background: var(--purple-light); }

    /* Hero */
    .hero {
      position: relative;
      padding: 80px 32px;
      text-align: center;
      border-bottom: 4px solid var(--purple-accent);
      overflow: hidden;
    }
    .hero::before {
      content: '';
      position: absolute;
      inset: 0;
      background: url("/Aerial-Drone-Downtown-Greensboro-North-Carolina-NC-Skyline.jpg") center/cover no-repeat;
      filter: grayscale(100%);
      z-index: 0;
    }
    .hero::after {
      content: '';
      position: absolute;
      inset: 0;
      background: rgba(59, 31, 110, 0.78);
      mix-blend-mode: multiply;
      z-index: 1;
    }
    .hero > * { position: relative; z-index: 2; }
    .hero h1 {
      font-size: clamp(28px, 5vw, 44px);
      font-weight: 700;
      color: var(--white);
      line-height: 1.2;
      margin-bottom: 16px;
    }
    .hero p {
      font-size: 18px;
      color: #c4a8f0;
      max-width: 560px;
      margin: 0 auto 32px;
    }
    .hero-btns { display: flex; gap: 12px; justify-content: center; flex-wrap: wrap; }
    .btn-primary {
      background: var(--white);
      color: var(--purple-dark);
      padding: 14px 28px;
      border-radius: 6px;
      font-size: 15px;
      font-weight: 600;
      border: none;
      cursor: pointer;
      text-decoration: none;
    }
    .btn-primary:hover { background: var(--purple-light); }
    .btn-secondary {
      background: transparent;
      color: var(--white);
      padding: 14px 28px;
      border-radius: 6px;
      font-size: 15px;
      font-weight: 600;
      border: 2px solid rgba(255,255,255,0.5);
      cursor: pointer;
      text-decoration: none;
    }
    .btn-secondary:hover { border-color: var(--white); background: rgba(255,255,255,0.08); }

    /* Sections */
    section { padding: 64px 32px; }
    .section-inner { max-width: 960px; margin: 0 auto; }
    .section-title { font-size: 30px; font-weight: 700; text-align: center; margin-bottom: 8px; color: var(--purple-dark); }
    .section-sub { font-size: 16px; color: var(--gray-mid); text-align: center; margin-bottom: 40px; }

    /* Services */
    .services { background: var(--white); }
    .services-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 20px; }
    .service-card {
      background: var(--gray-light);
      border: 1px solid #e2d9f3;
      border-radius: 10px;
      padding: 24px 20px;
      border-top: 3px solid var(--purple-accent);
    }
    .service-icon { font-size: 28px; margin-bottom: 12px; }
    .service-card h3 { font-size: 16px; font-weight: 600; margin-bottom: 8px; color: var(--purple-dark); }
    .service-card p { font-size: 14px; color: var(--gray-mid); line-height: 1.6; }

    /* About */
    .about { background: var(--purple-light); }
    .about-inner { max-width: 640px; margin: 0 auto; text-align: center; }
    .about-inner p { font-size: 16px; color: var(--gray-dark); line-height: 1.8; }

    /* Contact */
    .contact { background: var(--white); }
    .contact-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 48px;
      max-width: 720px;
      margin: 0 auto;
    }
    .contact-info h3 { font-size: 18px; font-weight: 600; margin-bottom: 20px; color: var(--purple-dark); }
    .contact-item { display: flex; align-items: center; gap: 12px; margin-bottom: 16px; font-size: 15px; color: var(--gray-dark); }
    .contact-item .icon { font-size: 18px; color: var(--purple-accent); min-width: 20px; text-align: center; font-style: normal; }
    .contact-form { display: flex; flex-direction: column; gap: 12px; }
    .contact-form input,
    .contact-form textarea {
      width: 100%;
      padding: 10px 14px;
      border: 1px solid #d1d5db;
      border-radius: 6px;
      font-size: 14px;
      font-family: inherit;
      background: var(--gray-light);
    }
    .contact-form input:focus,
    .contact-form textarea:focus { outline: 2px solid var(--purple-accent); border-color: transparent; }
    .contact-form textarea { height: 100px; resize: vertical; }
    .contact-form button {
      background: var(--purple-mid);
      color: var(--white);
      padding: 12px;
      border: none;
      border-radius: 6px;
      font-size: 15px;
      font-weight: 600;
      cursor: pointer;
      font-family: inherit;
    }
    .contact-form button:hover { background: var(--purple-dark); }

    /* Footer */
    footer {
      padding: 24px 32px;
      background: var(--purple-dark);
      text-align: center;
      font-size: 13px;
      color: #c4a8f0;
    }
    footer a { color: var(--white); }

    @media (max-width: 600px) {
      nav { padding: 12px 16px; }
      .hero { padding: 56px 20px; }
      section { padding: 48px 20px; }
      .contact-grid { grid-template-columns: 1fr; gap: 32px; }
    }
  </style>
</head>
<body>

  <nav>
    <a href="/" class="logo">
      <img src="/GCIT-Skyline-Logo.png" alt="Gate City IT" />
    </a>
    <a href="tel:3367431880" class="nav-cta">Call us</a>
  </nav>

  <section class="hero">
    <h1>Expert IT support for<br />Triad area small businesses</h1>
    <p>We keep your technology running so you can focus on running your business.</p>
    <div class="hero-btns">
      <a href="tel:3367431880" class="btn-primary">(336) 743-1880</a>
      <a href="#contact" class="btn-secondary">Book a Free Consultation</a>
    </div>
  </section>

  <section class="services">
    <div class="section-inner">
      <h2 class="section-title">What We Do</h2>
      <p class="section-sub">Comprehensive managed IT services for small businesses in the Triad</p>
      <div class="services-grid">
        <div class="service-card">
          <div class="service-icon">🛡️</div>
          <h3>Cybersecurity</h3>
          <p>Protect your business from threats with proactive monitoring and rapid response.</p>
        </div>
        <div class="service-card">
          <div class="service-icon">🎧</div>
          <h3>Help desk support</h3>
          <p>Fast, friendly support when your team needs it most — by phone, email, or helpdesk app.</p>
        </div>
        <div class="service-card">
          <div class="service-icon">☁️</div>
          <h3>Cloud services</h3>
          <p>Microsoft 365, cloud backup, and infrastructure management done right.</p>
        </div>
        <div class="service-card">
          <div class="service-icon">🖥️</div>
          <h3>Managed devices</h3>
          <p>Every workstation kept updated, patched, and running at peak performance.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="about">
    <div class="about-inner">
      <h2 class="section-title">About Gate City IT</h2>
      <p class="section-sub">Local experts, personal service</p>
      <p>We're a Greensboro-based IT company dedicated to helping small and medium businesses get enterprise-level technology support without the enterprise price tag. When you call us, you talk to someone who knows your business — not a distant call center.</p>
    </div>
  </section>

  <section class="contact" id="contact">
    <div class="section-inner">
      <h2 class="section-title">Get In Touch</h2>
      <p class="section-sub">We'd love to hear from you!</p>
      <div class="contact-grid">
        <div class="contact-info">
          <h3>Contact us directly</h3>
          <div class="contact-item">
            <span class="icon">&#9742;&#xFE0E;</span>
            <a href="tel:3367431880">(336) 743-1880</a>
          </div>
          <div class="contact-item">
            <span class="icon">&#9993;&#xFE0E;</span>
            <a href="mailto:info@gatecityit.com">info@gatecityit.com</a>
          </div>
          <div class="contact-item">
            <a href="https://linkedin.com" target="_blank" rel="noopener" style="display:flex; align-items:center; gap:10px; color: var(--gray-dark); text-decoration:none;">
              <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="var(--purple-accent)"><path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-10h3v10zm-1.5-11.268c-.966 0-1.75-.784-1.75-1.75s.784-1.75 1.75-1.75 1.75.784 1.75 1.75-.784 1.75-1.75 1.75zm13.5 11.268h-3v-5.604c0-1.337-.027-3.061-1.865-3.061-1.865 0-2.151 1.457-2.151 2.963v5.702h-3v-10h2.881v1.367h.041c.401-.761 1.381-1.563 2.844-1.563 3.042 0 3.604 2.002 3.604 4.604v5.592z"/></svg>
              Find us on LinkedIn
            </a>
          </div>
        </div>
        <form class="contact-form" name="contact" method="POST" action="https://api.web3forms.com/submit">
          <input type="hidden" name="access_key" value="48182325-7d17-4172-9472-4bb2f434c566" />
          <input type="hidden" name="subject" value="New contact form submission - Gate City IT" />
          <input type="checkbox" name="botcheck" style="display:none" />
          <input type="text" name="name" placeholder="Your name" required />
          <input type="email" name="email" placeholder="Email address" required />
          <input type="tel" name="phone" placeholder="Phone number" />
          <textarea name="message" placeholder="How can we help?"></textarea>
          <button type="submit">Send message →</button>
        </form>
      </div>
    </div>
  </section>

<footer>
    © 2026 Gate City IT · Greensboro, NC · <a href="tel:3367431880">(336) 743-1880</a>
    &nbsp;·&nbsp;
    <a href="/privacy-policy">Privacy policy</a>
    &nbsp;·&nbsp;
    <a href="/terms-of-service">Terms of service</a>
  </footer>

</body>
</html>
